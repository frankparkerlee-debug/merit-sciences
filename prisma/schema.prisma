// Merit Sciences — Affiliate Portal schema
//
// Product spec locked 2026-06-10:
//   - Tiered commission: 15% / 20% / 25% at 0-25 / 26-75 / 75+ orders
//     in the trailing 30 days, calculated at the moment of each order
//   - 30-day last-touch cookie attributes the FIRST purchase only
//   - At first purchase, a permanent customer↔affiliate lock is written
//   - All subsequent orders by that customer credit the affiliate
//     forever (evergreen) at the affiliate's CURRENT tier
//   - Self-purchases earn no commission
//   - Refunds clawback the commission
//   - Monthly payouts via Stripe Connect Express, $50 minimum, Net-30

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Affiliate ────────────────────────────────────────────────────────
// An approved promoter. One row per person/business that drives traffic.

model Affiliate {
  id                   String          @id @default(cuid())
  email                String          @unique
  name                 String
  // Public referral slug used in URLs (e.g. meritsciences.com?ref=alice)
  // Lowercase, alphanumeric + hyphen, 3-30 chars
  slug                 String          @unique
  // Custom discount code the affiliate sets at sign-up (e.g. "ParkerLee10",
  // "Founder"). Buyers type this at checkout to get 10% off; affiliate
  // earns commission. Lowercase, alphanumeric + hyphen, 3-30 chars.
  // Mapped to a Stripe Coupon when Stripe Checkout is wired.
  discountCode         String          @unique
  // Lifecycle. Open sign-up: ACTIVE by default; SUSPENDED for fraud/TOS.
  status               AffiliateStatus @default(ACTIVE)
  // Stripe Connect Express account id — set once payout onboarding done
  stripeAccountId      String?         @unique
  stripeChargesEnabled Boolean         @default(false)
  // Stripe Coupon + PromotionCode that back the buyer-facing discount.
  // Created lazily on affiliate signup (10% off, duration=forever).
  // Code-based attribution looks up Affiliate by stripePromotionCodeId
  // when the buyer uses the discount at Stripe Checkout.
  stripeCouponId          String? @unique
  stripePromotionCodeId   String? @unique
  // Supabase Auth user id (auth.users.id). Set on first sign-in.
  // Use this — NOT email — as the join key to look up the affiliate
  // for an authenticated request. Email is mutable and Supabase Auth
  // is the source of truth for it; using userId means email changes
  // just work without complex reconciliation.
  supabaseUserId          String? @unique
  // Optional fields collected at signup — surfaced to admin for fraud
  // review but no longer a gate to activation
  socialUrl            String?         // primary platform (Instagram, TikTok, etc.)
  audienceSize         Int?            // self-reported
  pitch                String?         @db.Text
  // Audit
  createdAt            DateTime        @default(now())
  suspendedAt          DateTime?
  suspendReason        String?         @db.Text

  // Relations
  clicks            Click[]
  customerLinks     CustomerAffiliateLink[]
  orderCommissions  OrderCommission[]
  payouts           Payout[]

  @@index([status])
  @@map("affiliates")
}

enum AffiliateStatus {
  ACTIVE    // can earn commissions, default on sign-up
  SUSPENDED // admin disabled (fraud, TOS violation)

  @@map("affiliate_status")
}

// ─── Click ────────────────────────────────────────────────────────────
// Logged every time someone hits the storefront with a ?ref= param.
// One row per click — used for affiliate stats and fraud detection
// (high click count, zero conversions → flag).

model Click {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  // PII collected: IP for fraud, UA for device split, referrer for source
  ipAddress   String?
  userAgent   String?   @db.Text
  referrer    String?   @db.Text
  landingPath String?   @db.Text // which page they landed on
  // Cookie identifier — links a click to a subsequent purchase
  cookieId    String // random uuid set in cookie, persisted here
  occurredAt  DateTime  @default(now())

  @@index([affiliateId, occurredAt])
  @@index([cookieId])
  @@map("clicks")
}

// ─── CustomerAffiliateLink ────────────────────────────────────────────
// The PERMANENT customer↔affiliate lock. Written ONCE, on first
// attributed purchase. Never updated. Every subsequent order by this
// customer credits the affiliate via this row.
//
// This is the evergreen mechanic. The row is the contract.

model CustomerAffiliateLink {
  id                   String    @id @default(cuid())
  // EMAIL is the canonical identity. We lock by lowercase email so the
  // evergreen attribution survives the buyer paying via PayPal one
  // time and a credit card the next, or moving between processors.
  customerEmail        String    @unique
  // External processor IDs are recorded for traceability but no longer
  // the unique key. Either or both can be set per row.
  paypalPayerId        String?   // PayPal payer.payer_id (when available)
  customerStripeId     String?   // Legacy — kept while Stripe path is removed
  affiliateId          String
  affiliate            Affiliate @relation(fields: [affiliateId], references: [id])
  // Audit
  lockedAt             DateTime  @default(now())
  sourceCookieId       String?   // which click led to the attribution
  sourceClickAt        DateTime? // when the click happened
  // Denormalized for fast tier calculation later. Avoids joining
  // on every commission calc.
  totalOrders          Int       @default(0)
  totalCommissionCents BigInt    @default(0)

  orderCommissions OrderCommission[]

  @@index([affiliateId])
  @@index([customerEmail])
  @@map("customer_affiliate_links")
}

// ─── OrderCommission ──────────────────────────────────────────────────
// One row per order that earns an affiliate commission. Written by the
// Stripe checkout.session.completed webhook.

model OrderCommission {
  id               String                @id @default(cuid())
  // External order identifier — PayPal order id (PRIMARY) or Stripe
  // checkout session id (LEGACY — kept while Stripe path is removed).
  // Exactly one of these is set per row going forward.
  paypalOrderId    String?               @unique
  paypalCaptureId  String?               @unique // PayPal capture (payment) id
  stripeSessionId  String?               @unique
  // External customer identifier:
  //   PayPal: payer_id from the captured order
  //   Stripe: customer id (legacy)
  paypalPayerId    String?
  customerStripeId String?
  // Snapshot the customer link state at the moment of the order
  customerLinkId   String
  customerLink     CustomerAffiliateLink @relation(fields: [customerLinkId], references: [id])
  affiliateId      String
  affiliate        Affiliate             @relation(fields: [affiliateId], references: [id])
  // Money — Stripe convention: integer cents
  orderTotalCents  BigInt // gross order subtotal (commissionable base)
  commissionRateBp Int    // basis points: 1500 = 15%, 2000 = 20%, 2500 = 25%
  commissionCents  BigInt // computed at order time, locks in this rate
  // Status — paid, unpaid, or clawed back
  status           CommissionStatus      @default(PENDING)
  // Payout link — set when this commission is included in a payout
  payoutId         String?
  payout           Payout?               @relation(fields: [payoutId], references: [id])
  // Clawback tracking
  clawedBackAt     DateTime?
  clawbackReason   String?
  // Audit
  occurredAt       DateTime              @default(now())

  @@index([affiliateId, occurredAt])
  @@index([affiliateId, status])
  @@index([customerLinkId])
  @@map("order_commissions")
}

enum CommissionStatus {
  PENDING     // earned, not yet eligible for payout (refund window open)
  PAYABLE     // refund window passed, ready to include in payout batch
  PAID        // included in a completed payout
  CLAWED_BACK // order was refunded, commission reversed

  @@map("commission_status")
}

// ─── Payout ───────────────────────────────────────────────────────────
// Monthly batch payouts via Stripe Connect Transfers.

model Payout {
  id               String       @id @default(cuid())
  affiliateId      String
  affiliate        Affiliate    @relation(fields: [affiliateId], references: [id])
  // Period this payout covers (calendar month boundaries)
  periodStart      DateTime
  periodEnd        DateTime
  // Money
  totalCents       BigInt // sum of included commissions
  // Status
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?      @unique
  paidAt           DateTime?
  failureReason    String?      @db.Text
  // Audit
  createdAt        DateTime     @default(now())

  orderCommissions OrderCommission[]

  @@index([affiliateId, periodStart])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING    // batch created, not yet sent to Stripe
  PROCESSING // Stripe Transfer initiated
  PAID       // Stripe confirmed transfer success
  FAILED     // Stripe transfer failed — needs admin attention

  @@map("payout_status")
}

// ─── Customer ─────────────────────────────────────────────────────────
// The buyer. ONE row per unique email (lowercase). Built up over time
// as the same email places more orders. Distinct from
// CustomerAffiliateLink which tracks the evergreen affiliate lock —
// the same customer may or may not have an affiliate locked.

model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  phone           String?
  // If the customer ever signs into an account, we link via Supabase Auth
  supabaseUserId  String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders Order[]

  @@index([email])
  @@map("customers")
}

// ─── Order ────────────────────────────────────────────────────────────
// One row per checkout that PayPal confirms paid. The PayPal capture
// is the source of truth for money; this row is OUR source of truth for
// fulfillment, customer service, and reporting.

model Order {
  id                String      @id @default(cuid())
  // External PayPal references.
  // - paypalOrderId is set when /api/paypal/create-order returns (we
  //   pre-create the Order row so buyer info from the card form is
  //   preserved — PayPal does NOT include payer.email on the order
  //   response after Advanced Card Fields capture).
  // - paypalCaptureId is set later when PAYMENT.CAPTURE.COMPLETED
  //   webhook fires. Nullable until capture confirmed.
  paypalOrderId     String      @unique
  paypalCaptureId   String?     @unique
  paypalPayerId     String?

  // Customer link
  customerId        String
  customer          Customer    @relation(fields: [customerId], references: [id])
  customerEmail     String      // denormalized for fast filter/search
  customerName      String      // snapshot at order time

  // Status state machine
  status            OrderStatus @default(PAID)

  // Money — integer cents (BigInt for safety on Postgres)
  subtotalCents     BigInt
  shippingCents     BigInt
  discountCents     BigInt      @default(0)
  totalCents        BigInt      // what was charged
  currency          String      @default("USD")

  // Affiliate context (if any) — denormalized; OrderCommission has the
  // commission ledger row keyed by paypalCaptureId
  discountCode      String?     // code typed at checkout (uppercase)
  affiliateId       String?     // affiliate credited (may differ from
                                // code if evergreen lock took over)

  // Shipping address (snapshotted JSON — we don't normalize because
  // each order is a point-in-time record)
  shippingFullName  String
  shippingLine1     String
  shippingLine2     String?
  shippingCity      String
  shippingState     String      // 2-char state code
  shippingZip       String
  shippingCountry   String      @default("US")
  shippingPhone     String?
  shippingEmail     String

  // Billing address (often same as shipping; we still snapshot)
  billingLine1      String?
  billingLine2      String?
  billingCity       String?
  billingState      String?
  billingZip        String?
  billingCountry    String?     @default("US")

  // Tracking — set by admin when order ships
  shippingCarrier   String?     // 'usps' | 'ups' | 'fedex' | 'dhl' | other
  trackingNumber   String?
  trackingUrl       String?     // auto-generated from carrier + number
  estimatedDeliveryAt DateTime?

  // RUO attestation — always true on our flow (gated by checkout), but
  // we record the IP + timestamp at the moment for compliance records
  ruoAttested       Boolean     @default(true)
  ruoAttestedIp     String?
  ruoAttestedAt     DateTime?

  // Internal admin notes (not shown to customer)
  internalNotes     String?     @db.Text

  // Lifecycle timestamps
  createdAt         DateTime    @default(now())
  paidAt            DateTime    @default(now())
  processingAt      DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  canceledAt        DateTime?
  refundedAt        DateTime?

  // Running total of refunds against this order (in cents). Incremented
  // on every full or partial refund. Net amount paid = totalCents - refundedCents.
  refundedCents     BigInt      @default(0)

  // Relations
  lines             OrderLine[]
  lookupTokens      OrderLookupToken[]
  events            OrderEvent[]

  @@index([customerEmail])
  @@index([status, createdAt])
  @@index([affiliateId])
  @@map("orders")
}

enum OrderStatus {
  PENDING_PAYMENT       // pre-created at checkout, waiting for capture webhook
  PAID                  // money in, not yet picked
  PROCESSING            // picking / fulfilling
  SHIPPED               // tracking number assigned, package out the door
  DELIVERED             // carrier confirmed delivery (manual or webhook)
  CANCELED              // canceled before shipping
  REFUNDED              // full refund issued
  PARTIALLY_REFUNDED    // partial refund issued (rare for this catalog)

  @@map("order_status")
}

// ─── OrderLine ────────────────────────────────────────────────────────
// One row per cart line. Snapshots title, bundle label, and unit price
// at the moment of purchase — does NOT reference live product data
// because products and prices change but the order doesn't.

model OrderLine {
  id           String @id @default(cuid())
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  handle       String // product handle for warehouse pick (e.g. 'bpc-157')
  title        String // snapshot at purchase
  bundleLabel  String // e.g. 'Single vial' or 'Subscribe · Every month'
  unitCents    BigInt
  qty          Int
  // Snapshot for fulfillment — components of a stack
  components   String[] @default([])
  imageUrl     String?

  @@index([orderId])
  @@map("order_lines")
}

// ─── OrderLookupToken ─────────────────────────────────────────────────
// Magic-link token issued when a customer enters email + order # on
// the public lookup page. Single-use, 24-hour expiry. Lets them view
// their order detail page without an account.

model OrderLookupToken {
  id          String   @id @default(cuid())
  // The opaque token included in the magic link
  token       String   @unique
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Email the link was sent to — must match Order.customerEmail
  email       String
  // Lifecycle
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  usedAt      DateTime?
  // Where the request came from — useful for fraud / abuse review
  requestIp   String?

  @@index([orderId])
  @@index([expiresAt])
  @@map("order_lookup_tokens")
}

// ─── OrderEvent ───────────────────────────────────────────────────────
// Append-only activity timeline for an order. Every state change writes
// one row: placed, payment captured, emails sent, status transitions,
// refunds, admin comments. Renders chronologically on the order detail
// page (Shopify-style timeline).
//
// System events have actorEmail = null. Admin-triggered events store
// the operator's email so the timeline shows "JP marked as shipped"
// vs "System captured payment."

model OrderEvent {
  id          String         @id @default(cuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // What happened
  kind        OrderEventKind
  // Human-readable summary rendered in the timeline
  message     String         @db.Text
  // Structured payload for richer rendering (tracking #, email id,
  // refund amount, etc.). Avoids parsing the message string.
  metadata    Json?
  // Admin who triggered the event. NULL for system events
  // (webhook, scheduled email, etc.)
  actorEmail  String?
  createdAt   DateTime       @default(now())

  @@index([orderId, createdAt])
  @@map("order_events")
}

enum OrderEventKind {
  ORDER_PLACED             // customer completed checkout
  PAYMENT_CAPTURED         // PayPal capture confirmed (webhook or recheck)
  CONFIRMATION_EMAIL_SENT  // customer order confirmation
  ADMIN_NOTIFIED           // ops team notification email fired
  MARKED_PROCESSING        // admin clicked Mark Processing
  LABEL_PURCHASED          // recorded when ShipStation pushes back (future)
  MARKED_SHIPPED           // admin marked shipped + entered tracking
  SHIPMENT_EMAIL_SENT      // customer shipment notification
  MARKED_DELIVERED         // admin marked delivered
  MARKED_CANCELED          // admin canceled (no money movement)
  REFUND_FULL              // PayPal full refund issued
  REFUND_PARTIAL           // PayPal partial refund issued
  COMMISSION_CLAWED_BACK   // affiliate commission rolled back on refund
  ADMIN_COMMENT            // free-text note from an admin
  EMAIL_FAILED             // any email send returned not-ok from Resend

  @@map("order_event_kind")
}

// ─── Discount ─────────────────────────────────────────────────────────
// Manual / promo discount codes managed from the admin. Separate from
// affiliate codes (which live on the Affiliate model) but unified in
// the admin UI. Lookup at checkout is case-insensitive on `code`.

model Discount {
  id              String         @id @default(cuid())
  // Case-insensitive code; stored lowercase, unique
  code            String         @unique
  // Display title shown in admin lists; if null fall back to code
  title           String?
  type            DiscountType
  // PERCENT: basis points (10% = 1000, 25% = 2500, max 10000)
  // FIXED_AMOUNT: cents off the order
  // FREE_SHIPPING: value not used (set to 0)
  value           Int
  method          DiscountMethod @default(CODE)
  // Eligibility / restrictions
  minPurchaseCents BigInt?
  minQuantity      Int?
  maxUses          Int?           // null = unlimited
  oncePerCustomer  Boolean        @default(false)
  // Bonus: stack free shipping on top of the main discount type. Lets
  // codes like "WELCOME20" give 20% off subtotal AND zero shipping in
  // one code, instead of forcing two separate codes. Set independently
  // of `type` — except FREE_SHIPPING type implies this is true anyway.
  freeShipping     Boolean        @default(false)
  // Optional restriction to a single customer email
  customerEmail    String?
  // Schedule
  startsAt        DateTime        @default(now())
  endsAt          DateTime?
  // Lifecycle
  status          DiscountStatus  @default(ACTIVE)
  // Denormalized usage counter — incremented when an order successfully
  // applies this code. Authoritative count is COUNT(orders WHERE discountCode=this.code).
  usedCount       Int             @default(0)
  // Audit
  createdAt       DateTime        @default(now())
  createdByEmail  String?

  @@index([status, startsAt])
  @@map("discounts")
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
  FREE_SHIPPING

  @@map("discount_type")
}

enum DiscountMethod {
  CODE         // customer types code at checkout
  AUTOMATIC    // applied at checkout when conditions match

  @@map("discount_method")
}

enum DiscountStatus {
  ACTIVE
  DISABLED
  // EXPIRED is computed (endsAt < now) not stored, but kept here for
  // tag-based filtering in the admin list query.
  EXPIRED

  @@map("discount_status")
}

// ─── Product ──────────────────────────────────────────────────────────
// Mirrors the storefront Product TS type (lib/product-types.ts). Source
// of truth for catalog/PDP rendering. Spec + lot fields are flattened
// from nested JSON so the admin edit form can bind to scalar inputs.
// `bundles` and `images` stay JSON/string-array because their length
// is variable.

model Product {
  // Handle = URL slug = primary key (stable across renames)
  handle              String   @id
  title               String
  compound            String
  eyebrow             String
  vialSize            String
  format              ProductFormat
  oneLiner            String   @db.Text
  // Retail price = priceCents (kept as-is for storefront compatibility).
  // Customers always see this unless they're logged into the physician
  // portal, in which case they see physicianPriceCents instead.
  priceCents          Int
  compareAtCents      Int?
  // Physician-channel pricing (wholesale-like). NEVER exposed to retail
  // customers. Only visible inside the gated /physician portal.
  physicianPriceCents Int?
  // Internal margin tracking. NEVER exposed externally.
  costCents           Int?
  // On-hand inventory (units in stock with zero lead time). Updated by
  // the inventory CSV importer + by ShipStation shipment events later.
  stockQty            Int                  @default(0)

  // Bundle SKUs (3-pack, subscribe, etc) — array of { label, vials, priceCents }
  bundles             Json?

  // Spec block (flattened from spec.* in legacy JSON)
  specCas             String?
  specMw              String?
  specFormula         String?
  specSequence        String?  @db.Text
  specAminoAcids      Int?

  // Lot info (flattened from lot.* in legacy JSON)
  lotId               String
  lotPurity           String
  lotTestedDate       String   // ISO date string; left as String to match existing
  lotBud              String
  lotCoaUrl           String?

  segment             ProductSegment
  channel             ProductChannel
  shopifySuspended    Boolean        @default(false)
  status              ProductStatus  @default(ACTIVE)

  // Primary image + gallery
  imageUrl            String?
  images              String[]       @default([])

  // Audit
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, channel])
  @@index([segment])
  @@map("products")
}

enum ProductFormat {
  LYOPHILIZED
  RECONSTITUTED

  @@map("product_format")
}

enum ProductSegment {
  BIOHACKER
  CLINIC
  AESTHETIC
  ATHLETIC
  RESEARCHER

  @@map("product_segment")
}

enum ProductChannel {
  RUA       // research use only — public storefront
  CLINIC    // clinic-only gated
  BOTH

  @@map("product_channel")
}

enum ProductStatus {
  ACTIVE
  DRAFT

  @@map("product_status")
}
